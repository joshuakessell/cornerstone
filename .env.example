# Copy to .env and fill in values. NEVER commit .env.
# .env is gitignored.

# ---- Server-side only (NEVER prefix with NEXT_PUBLIC_) ----
# (Add secrets here — e.g. CLIO_API_KEY if server-side Clio calls are added)

# ---- Client-side safe (public, non-sensitive) ----
# NEXT_PUBLIC_* vars are exposed in the browser bundle. Never put secrets here.
# NEXT_PUBLIC_CLIO_EMBED_URL=
# NEXT_PUBLIC_SITE_URL=https://cornerstonelawgroup.com

# ---- Agent Teams (required for claude-bootstrap team workflow) ----
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
